{
  "name": "@ordnary/pay-sdk",
  "version": "0.2.0",
  "description": "Safe client SDK for Ordnary Pay payment-method management",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "openapi.yaml"
  ],
  "keywords": [
    "ordnary",
    "payments",
    "stripe",
    "sdk",
    "pay"
  ],
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "license": "MIT"
}
